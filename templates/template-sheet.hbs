{{!-- acks-lib.template builder sheet body. Self-contained (no partials).
      Every selector is scoped under .acks-lib-template-sheet. --}}
<div class="acks-lib-template-body">

  {{#if isStub}}
    <p class="acks-lib-template-warning">{{localize "ACKS-LIB.template.stubNote"}}</p>
  {{/if}}

  {{!-- The optional BASE actor: drop a victim on the sheet to modify it
        (vampire thrall); leave empty to self-generate (dragon, elemental). --}}
  <section class="acks-lib-template-base">
    <header><h3>{{localize "ACKS-LIB.template.base"}}</h3></header>
    {{#if base}}
      <div class="base-row">
        <span class="base-name">{{base.name}}</span>
        {{#if editable}}
          <button type="button" class="icon" data-action="clearBase"
                  title="{{localize 'ACKS-LIB.template.clearBase'}}">✕</button>
        {{/if}}
      </div>
    {{else}}
      <p class="hint">{{localize "ACKS-LIB.template.dropBase"}}</p>
    {{/if}}
  </section>

  {{!-- One select per axis. Empty = roll per the book's own procedure;
        an axis that derives from the base says so. --}}
  {{#if axes.length}}
    <section class="acks-lib-template-axes">
      {{#each axes}}
        <label class="axis-row">
          <span class="axis-label">{{label}}</span>
          <select class="acks-lib-template-pin" data-axis="{{key}}">
            <option value="">{{#if derived}}{{localize "ACKS-LIB.template.derived"}}{{else}}{{rollLabel}}{{/if}}</option>
            {{#each options}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
      {{/each}}
    </section>
  {{/if}}

  {{#if hasMenu}}
    <p class="acks-lib-template-menu-note hint">{{menuNote}}</p>
  {{/if}}

  {{#if editable}}
    <section class="acks-lib-template-controls">
      <button type="button" data-action="generate" {{#if isStub}}disabled{{/if}}>
        <i class="fas fa-dice-d20"></i> {{localize "ACKS-LIB.template.generate"}}
      </button>
    </section>
  {{/if}}

  {{#if biographyHTML}}
    <section class="acks-lib-template-description">
      {{{biographyHTML}}}
    </section>
  {{/if}}

</div>
